from sklearn.tree import DecisionTreeClassifier
from sklearn.ensemble import RandomForestClassifier, AdaBoostClassifier, GradientBoostingClassifier
from sklearn.utils.class_weight import compute_sample_weight
from sklearn.model_selection import GridSearchCV
# Default training
results_tree = []

models_tree = [
    ("Decision Tree", DecisionTreeClassifier(random_state=77, class_weight="balanced")),
    ("Random Forest", RandomForestClassifier(random_state=42, n_jobs=-1, class_weight="balanced")),
    ("AdaBoost", AdaBoostClassifier(random_state=77, algorithm="SAMME")),
    ("Gradient Boosting", GradientBoostingClassifier(random_state=77)),
]

sample_weights = compute_sample_weight(class_weight="balanced", y=y_train)

for name, model in models_tree:
    if name in ["AdaBoost", "Gradient Boosting"]:
        model.fit(X_train_sel, y_train, sample_weight=sample_weights)

        y_prob = model.predict_proba(X_test_sel)[:, 1]
        y_pred = (y_prob >= 0.5).astype(int)

        tn, fp, fn, tp = confusion_matrix(y_test, y_pred).ravel()
        specificity = tn / (tn + fp)

        result = {"Model": name,
                  "Accuracy": accuracy_score(y_test, y_pred),
                  "Precision": precision_score(y_test, y_pred, zero_division=0),
                  "Recall": recall_score(y_test, y_pred, zero_division=0),
                  "Specificity": specificity,
                  "ROC_AUC": roc_auc_score(y_test, y_prob)}
    else:
        result = evaluate_model(name, model, X_train_sel, y_train, X_test_sel, y_test)

    results_tree.append(result)

results_df_tree = pd.DataFrame(results_tree).sort_values(by="ROC_AUC", ascending=False)
results_df_tree

