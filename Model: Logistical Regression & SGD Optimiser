    ("Logistic Regression L1", LogisticRegression(penalty = "l1", solver="saga", C=0.1, max_iter=2000, class_weight="balanced")),
    ("Logistic Regression L2", LogisticRegression(penalty = "l2", solver="saga", C=0.1, max_iter=2000, class_weight="balanced")),
    ("Elastic Net", LogisticRegression(penalty = "elasticnet", solver="saga", C=0.1, l1_ratio=0.5, max_iter=2000, class_weight="balanced")),
    ("SGD Log Loss", SGDClassifier(loss="log_loss", max_iter=2000, class_weight="balanced", random_state=77)),
]

for name, model in models_log:
    result = evaluate_model(name, model, X_train_sel, y_train, X_test_sel, y_test)
    results_log.append(result)

results_df_log = pd.DataFrame(results_log).sort_values(by="ROC_AUC", ascending=False)
